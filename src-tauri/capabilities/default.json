{
  "identifier": "default",
  "description": "Default capabilities for ParseKit",
  "windows": ["main", "onboarding", "progress-hud"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "shell:default",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "clipboard-manager:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered",
    "updater:default",
    "core:event:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/parsekit-sidecar", "sidecar": true, "args": false }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/parsekit-sidecar", "sidecar": true, "args": false }
      ]
    }
  ]
}